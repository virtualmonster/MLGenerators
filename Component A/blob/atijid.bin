    {
		   	
        
		var app = this.getPage().getForm().getApp();
		var form = this.getPage().getForm();
		var page = this.getPage();
    	var BO = this.getBO();
    	var BOA = this.getBOAttr();
    	var field = this;
    	var item = this;
    	var get = freedom.client.util.unsecureGet;
    	var set = freedom.client.util.unsecureSet;
    	var forEach = freedom.client.util.unsecureForEach;
    	//reset products list to combined
var AIProds = BO.F_AIProducts.getValue();
var DataProds = BO.F_DataProducts.getValue();
var DTProds = BO.F_DTProducts.getValue();
var ESProds = BO.F_ESProducts.getValue();
var OtherProds = BO.F_OtherProducts.getValue();
var ProdList = "";
if (AIProds) {
  ProdList = AIProds;
}
if (DataProds) {
  if(ProdList){
     ProdList = ProdList + "_#_"+DataProds;
  } else {
    ProdList = DataProds;
  }
}
if (DTProds) {
  if(ProdList){
     ProdList = ProdList + "_#_"+DTProds;
  } else {
    ProdList = DTProds;
  }
}
if (ESProds) {
  if(ProdList){
     ProdList = ProdList + "_#_"+ESProds;
  } else {
    ProdList = ESProds;
  }
}
if (OtherProds) {
  if(ProdList){
     ProdList = ProdList + "_#_"+OtherProds;
  } else {
    ProdList = OtherProds;
  }
}
console.log(ProdList);
BO.F_SelectedProducts.setValue(ProdList);

    }
    catch (origErr)
    {
    
    	freedom.client.util.handleEventCodeError(
    	    this.__widget, 
    	    "onItemChange", 
    	    origErr, 
    	    "Form 1", 
    	    "Hidden", 
    	    "Which Digital Transformation products?"
    	);
    }
    	
}}   
